{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OmniSpace",
  "version": "0.1.0",
  "identifier": "com.omnispace.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OmniSpace",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost blob:; frame-src https://www.youtube.com asset: https://asset.localhost blob:; media-src 'self' data: asset: https://asset.localhost blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNENjA0MzY5QjcwNDc2MUEKUldRYWRnUzNhVU5nUFYyb1JEK3I3OWZVSjZzSHF0T3Fvb2ZLMWlJM0VzMFNXNnoycWx5dnlFdmoK",
      "endpoints": [
        "https://github.com/Thor342/omnispace/releases/latest/download/latest.json"
      ]
    }
  }
}
